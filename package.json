{
  "name": "clawpal-connect",
  "version": "1.0.4",
  "description": "Hosted-relay host connector CLI for ClawPal",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "clawpal": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/StevYin8/clawpal-connect.git"
  },
  "homepage": "https://github.com/StevYin8/clawpal-connect#readme",
  "bugs": {
    "url": "https://github.com/StevYin8/clawpal-connect/issues"
  },
  "keywords": [
    "clawpal",
    "connector",
    "relay",
    "cli",
    "openclaw"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "npm run build",
    "dev": "tsx src/cli.ts demo",
    "status": "tsx src/cli.ts status",
    "bind": "tsx src/cli.ts bind",
    "start:dev": "tsx src/cli.ts start --transport mock",
    "demo": "tsx src/cli.ts demo",
    "start": "node dist/cli.js start",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run build && npm run test",
    "release:check": "npm run check && npm pack --dry-run"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^2.1.8"
  }
}
