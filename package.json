{
  "name": "clawpal-connect",
  "version": "0.2.0",
  "description": "Hosted-relay host connector CLI for ClawPal",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "npm run build",
    "dev": "tsx src/cli.ts demo",
    "status": "tsx src/cli.ts status",
    "bind": "tsx src/cli.ts bind",
    "start:dev": "tsx src/cli.ts start --transport mock",
    "demo": "tsx src/cli.ts demo",
    "start": "node dist/cli.js start",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run build && npm run test",
    "postinstall": "node -e \"const fs=require('fs'),path=require('path');const prefix=(process.env.npm_config_prefix||'').trim();const pkg=(process.env.npm_package_json||'').trim();if(!prefix||!pkg){process.exit(0)};const root=path.dirname(pkg);const dist=path.join(root,'dist');if(!fs.existsSync(dist)){process.exit(0)};const stable=path.join(prefix,'lib','clawpal-standalone');fs.rmSync(stable,{recursive:true,force:true});fs.mkdirSync(stable,{recursive:true});fs.cpSync(dist,path.join(stable,'dist'),{recursive:true});const bin=path.join(prefix,'bin','clawpal');fs.rmSync(bin,{force:true});fs.writeFileSync(bin,`#!/bin/sh\nexec node \"${path.join(stable,'dist','cli.js')}\" \"$@\"\n`);fs.chmodSync(bin,0o755);\""
  },
  "dependencies": {
    "commander": "^12.1.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^2.1.8"
  }
}
